{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Blocksmith",
  "version": "0.1.0",
  "identifier": "com.blocksmith.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Blocksmith",
        "width": 1480,
        "height": 940,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}

